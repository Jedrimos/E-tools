# Supabase Konfiguration
# 1. Gehe zu https://supabase.com und erstelle ein kostenloses Konto
# 2. Erstelle ein neues Projekt
# 3. Gehe zu Settings → API
# 4. Kopiere Project URL und anon/public key hierher
# 5. Benenne diese Datei in .env um

VITE_SUPABASE_URL=https://DEINE-PROJEKT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key-hier
